}

# ==========================================
# 2. BFS Algorithm with Logging
# ==========================================

def search_bfs_with_log(start, target):
    queue = [[start]]
    visited = {start}
    log_steps = []

    log_steps.append(f"Start BFS from [{start}]")

    while queue:
        path = queue.pop(0)
        current = path[-1]

        log_steps.append(f"Visiting: {current}")

        if current == target:
            log_steps.append("Target found using BFS")
            return path, log_steps

        log_steps.append(f"Neighbors: {[n for n, _ in genre_graph.get(current, [])]}")

        for neighbor, _ in genre_graph.get(current, []):
            if neighbor not in visited:
                visited.add(neighbor)
                new_path = list(path)
                new_path.append(neighbor)
                queue.append(new_path)
                log_steps.append(f"Added to queue: {neighbor}")

    return None, log_steps


# ==========================================
# 3. A* Algorithm with Logging
# ==========================================

def get_heuristic(current, target):
    x1, y1 = genres_data[current]["coords"]
    x2, y2 = genres_data[target]["coords"]
    return round(((x1 - x2) ** 2 + (y1 - y2) ** 2) ** 0.5, 2)


def search_astar_with_log(start, target):
    pq = PriorityQueue()
    pq.put((get_heuristic(start, target), [start]))

    g_score = {genre: float('inf') for genre in genres_data}
    g_score[start] = 0

    log_steps = []
    log_steps.append(f"Start A* from [{start}]")

    while not pq.empty():
        f, path = pq.get()
        current = path[-1]

        log_steps.append(f"Checking: {current}")

        if current == target:
            log_steps.append("Target found using A*")
            return path, log_steps

        for neighbor, weight in genre_graph.get(current, []):
            tentative_g = g_score[current] + weight

            if tentative_g < g_score[neighbor]:
                g_score[neighbor] = tentative_g
                h = get_heuristic(neighbor, target)
                f_score = tentative_g + h

                new_path = list(path)
                new_path.append(neighbor)
                pq.put((f_score, new_path))

                log_steps.append(f"{neighbor} -> g={tentative_g}, h={h}, f={f_score}")

    return None, log_steps


