# 4. GUI Application
# ==========================================

class MovieSearchApp(ctk.CTk):
    def __init__(self):
        super().__init__()

        self.title("Movie Search System (AI Graph)")
        self.geometry("850x620")
        ctk.set_appearance_mode("dark")

        self.grid_rowconfigure(1, weight=1)
        self.grid_columnconfigure(1, weight=1)

        # Title
        self.title_label = ctk.CTkLabel(
            self,
            text="Movie Search System",
            font=ctk.CTkFont(size=24, weight="bold")
        )
        self.title_label.grid(row=0, column=0, columnspan=2, pady=10)

        # Sidebar
        self.sidebar = ctk.CTkFrame(self, width=250)
        self.sidebar.grid(row=1, column=0, padx=10, pady=10, sticky="nsew")

        self.target_combo = ctk.CTkComboBox(
            self.sidebar,
            values=list(genres_data.keys())
        )
        self.target_combo.pack(pady=20)
        self.target_combo.set("Romance")

        self.algo_var = ctk.StringVar(value="BFS")

        self.bfs_radio = ctk.CTkRadioButton(
            self.sidebar, text="BFS", variable=self.algo_var, value="BFS"
        )
        self.bfs_radio.pack(pady=10)

        self.astar_radio = ctk.CTkRadioButton(
            self.sidebar, text="A*", variable=self.algo_var, value="A*"
        )
        self.astar_radio.pack(pady=10)

        self.search_btn = ctk.CTkButton(
            self.sidebar,
            text="Search",
            command=self.run_search
        )
        self.search_btn.pack(pady=20)

        # Main area
        self.main = ctk.CTkFrame(self)
        self.main.grid(row=1, column=1, padx=10, pady=10, sticky="nsew")

        self.output = ctk.CTkTextbox(self.main)
        self.output.pack(fill="both", expand=True, padx=10, pady=10)

    def run_search(self):
        start = "Action"
        target = self.target_combo.get()
        algo = self.algo_var.get()

        if algo == "BFS":
            path, log = search_bfs_with_log(start, target)
        else:
            path, log = search_astar_with_log(start, target)

        self.output.delete("1.0", "end")

        if path:
            self.output.insert("end", "Path: " + " -> ".join(path) + "\n\n")
            self.output.insert("end", "\n".join(log))
        else:
            self.output.insert("end", "No path found")


if __name__ == "__main__":
    app = MovieSearchApp()
    app.mainloop()
